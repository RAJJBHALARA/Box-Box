# ===========================
# PitWall AI — Root .gitignore
# ===========================

# OS Files
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

# Editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Screenshots (add your own)
# screenshots/

# Environment files — NEVER commit these
.env
.env.local
.env.*.local

# ===========================
# Frontend (Node / Vite)
# ===========================
frontend/node_modules/
frontend/dist/
frontend/.cache/

# ===========================
# Backend (Python)
# ===========================
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd
backend/venv/
backend/.venv/
backend/env/
backend/.env
backend/cache/
backend/*.egg-info/
backend/dist/
backend/build/
backend/.pytest_cache/
backend/.mypy_cache/

# ===========================
# Docker (future use)
# ===========================
*.dockerignore
